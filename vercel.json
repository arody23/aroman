{
  "version": 2,
  "installCommand": "npm install",
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "includeFiles": "views/**"
    },
    "api/env-check.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/health/env", "destination": "/api/env-check" },
    {
      "source": "/((?!css/|js/|assets/|uploads/|favicon\\.ico|deploy-check\\.txt|health/).*)",
      "destination": "/api"
    }
  ]
}
