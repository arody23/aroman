<!DOCTYPE html>
<html lang="fr">
<head>
  <%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/header') %>

  <section class="page-hero">
    <div class="container">
      <span class="section-tag">Contact</span>
      <h1>Demande de projet</h1>
      <p class="page-hero-lead">Décrivez votre besoin et je vous répondrai dans les meilleurs délais.</p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-layout">
      <div class="contact-info reveal">
        <h2>Coordonnées</h2>
        <ul class="contact-list">
          <li><strong>Email</strong><a href="mailto:contact@aromanemetshu.com">contact@aromanemetshu.com</a></li>
          <li><strong>WhatsApp</strong><a href="https://wa.me/242067458011" target="_blank" rel="noopener">+242 06 745 8011</a></li>
          <li><strong>Adresse</strong>2, Rue Mampouya, Moukondo, Brazzaville, Congo</li>
        </ul>
      </div>

      <form class="contact-form reveal" id="contact-form" novalidate>
        <fieldset>
          <legend>Services souhaités</legend>
          <div class="checkbox-grid">
            <% const services = ['Développement de site web','Développement SaaS','Développement logiciel','Développement PWA','Application métier','Stratégie marketing','Facebook Ads','Google Ads','Audit marketing','Autre']; %>
            <% services.forEach(function(s) { %>
            <label class="checkbox-label">
              <input type="checkbox" name="services" value="<%= s %>">
              <span><%= s %></span>
            </label>
            <% }); %>
          </div>
        </fieldset>

        <div class="form-row">
          <div class="form-group">
            <label for="name">Nom *</label>
            <input type="text" id="name" name="name" required autocomplete="name">
          </div>
          <div class="form-group">
            <label for="company">Entreprise</label>
            <input type="text" id="company" name="company" autocomplete="organization">
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="phone">Téléphone</label>
            <input type="tel" id="phone" name="phone" autocomplete="tel">
          </div>
          <div class="form-group">
            <label for="email">Email *</label>
            <input type="email" id="email" name="email" required autocomplete="email">
          </div>
        </div>

        <div class="form-group">
          <label for="description">Description du projet *</label>
          <textarea id="description" name="description" rows="6" required placeholder="Décrivez votre projet, vos objectifs et vos contraintes…"></textarea>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary btn-lg" id="submit-btn">Envoyer la demande</button>
        </div>
        <div class="form-message" id="form-message" role="alert" hidden></div>
      </form>
    </div>
  </section>

  <%- include('../partials/footer') %>
  <script src="/js/main.js" defer></script>
  <script src="/js/contact.js" defer></script>
</body>
</html>
