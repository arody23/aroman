<!DOCTYPE html>
<html lang="fr">
<head>
  <%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/header') %>

  <!-- Hero -->
  <section class="hero" id="accueil">
    <div class="hero-bg"></div>
    <div class="container hero-content">
      <p class="hero-eyebrow">Développeur & Media Buyer</p>
      <h1>Aroman EMETSHU</h1>
      <p class="hero-lead">Je conçois des solutions digitales performantes et pilote des campagnes publicitaires à fort impact. Développement web, logiciels, SaaS et Media Buying — avec la même exigence de qualité.</p>
      <div class="hero-actions">
        <a href="/contact" class="btn btn-primary">Démarrer un projet</a>
        <a href="/realisations" class="btn btn-outline">Voir mes réalisations</a>
      </div>
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-value">5+</span>
          <span class="stat-label">ans d'expérience</span>
        </div>
        <div class="stat">
          <span class="stat-value">50+</span>
          <span class="stat-label">projets livrés</span>
        </div>
        <div class="stat">
          <span class="stat-value">2</span>
          <span class="stat-label">expertises majeures</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Présentation -->
  <section class="section section-presentation">
    <div class="container split-layout">
      <div class="split-content reveal-left">
        <span class="section-tag">Présentation</span>
        <h2>Développement logiciel & acquisition digitale</h2>
        <p>Fort de plus de cinq ans d'expérience, j'accompagne entreprises et entrepreneurs dans la création de solutions digitales sur mesure — sites web, applications, SaaS, logiciels métier — tout en optimisant leur visibilité grâce à des stratégies Media Buying ciblées.</p>
        <p>Mon approche combine rigueur technique et vision stratégique. Chaque projet est pensé pour durer, performer et générer des résultats mesurables.</p>
        <a href="/a-propos" class="link-arrow">En savoir plus</a>
      </div>
      <div class="split-visual reveal-right">
        <div class="visual-card">
          <div class="visual-card-inner">
            <span class="visual-icon">&#9670;</span>
            <h3>Code & Stratégie</h3>
            <p>De l'architecture logicielle à l'optimisation des campagnes publicitaires.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Expertises -->
  <section class="section section-expertises bg-subtle">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-tag">Expertises</span>
        <h2>Deux domaines, une même exigence</h2>
        <p>Développement et Media Buying sont au cœur de mon activité, avec un niveau d'importance égal.</p>
      </div>
      <div class="expertise-grid">
        <article class="expertise-card reveal">
          <div class="expertise-icon dev-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M4 6.5C4 5.12 5.12 4 6.5 4H17.5C18.88 4 20 5.12 20 6.5V13.5C20 14.88 18.88 16 17.5 16H10L6 19.5V16H6.5C5.12 16 4 14.88 4 13.5V6.5Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
              <path d="M8.5 8.5L6.5 10.5L8.5 12.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M12.5 12.5H15.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
            </svg>
          </div>
          <h3>Développement</h3>
          <ul>
            <li>Sites web professionnels</li>
            <li>Applications web & SaaS</li>
            <li>Logiciels d'entreprise</li>
            <li>Applications métier & PWA</li>
            <li>Solutions IA (sur mesure)</li>
          </ul>
          <a href="/expertises#developpement" class="link-arrow">Détails</a>
        </article>
        <article class="expertise-card reveal">
          <div class="expertise-icon media-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M4 19V5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
              <path d="M4 19H20" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
              <path d="M8 15V11" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              <path d="M12 15V8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              <path d="M16 15V5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              <path d="M12 5L15.5 8.5L20 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3>Media Buying</h3>
          <ul>
            <li>Facebook & Instagram Ads</li>
            <li>Google Ads</li>
            <li>Stratégies d'acquisition</li>
            <li>Optimisation de campagnes</li>
            <li>Consulting marketing</li>
          </ul>
          <a href="/expertises#media-buying" class="link-arrow">Détails</a>
        </article>
      </div>
    </div>
  </section>

  <!-- Pourquoi moi -->
  <section class="section section-why">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-tag">Pourquoi travailler avec moi</span>
        <h2>Un partenaire, pas un prestataire</h2>
      </div>
      <div class="why-grid">
        <div class="why-item reveal">
          <span class="why-number">01</span>
          <h3>Double compétence</h3>
          <p>Développeur et Media Buyer — une vision complète de votre écosystème digital.</p>
        </div>
        <div class="why-item reveal">
          <span class="why-number">02</span>
          <h3>Résultats mesurables</h3>
          <p>Chaque livrable et chaque campagne sont évalués sur des indicateurs concrets.</p>
        </div>
        <div class="why-item reveal">
          <span class="why-number">03</span>
          <h3>Qualité premium</h3>
          <p>Code propre, design soigné, stratégies affinées. Pas de compromis sur l'excellence.</p>
        </div>
        <div class="why-item reveal">
          <span class="why-number">04</span>
          <h3>Proximité & réactivité</h3>
          <p>Basé entre Kinshasa et Brazzaville, disponible pour un accompagnement direct.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Réalisations récentes -->
  <% if (projects.length > 0) { %>
  <section class="section section-projects bg-subtle">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-tag">Réalisations</span>
        <h2>Projets récents</h2>
        <p>Sites web, applications et solutions digitales développées pour mes clients.</p>
      </div>
      <div class="project-grid">
        <% projects.forEach(function(p) { %>
        <article class="project-card reveal">
          <% if (p.cover_image) { %>
          <div class="project-image"><img src="<%= p.cover_image %>" alt="<%= p.title %>" loading="lazy" width="400" height="250"></div>
          <% } else { %>
          <div class="project-image project-image-placeholder"></div>
          <% } %>
          <div class="project-body">
            <span class="project-category"><%= p.category || 'Web' %></span>
            <h3><%= p.title %></h3>
            <p><%= p.description ? p.description.substring(0, 120) + (p.description.length > 120 ? '…' : '') : '' %></p>
            <% if (p.project_url) { %>
            <a href="<%= p.project_url %>" target="_blank" rel="noopener" class="link-arrow">Voir le projet</a>
            <% } %>
          </div>
        </article>
        <% }); %>
      </div>
      <div class="section-cta reveal">
        <a href="/realisations" class="btn btn-outline">Toutes les réalisations</a>
      </div>
    </div>
  </section>
  <% } %>

  <!-- Campagnes récentes -->
  <% if (campaigns.length > 0) { %>
  <section class="section section-campaigns">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-tag">Campagnes</span>
        <h2>Résultats obtenus</h2>
        <p>Des campagnes publicitaires optimisées pour maximiser le retour sur investissement.</p>
      </div>
      <div class="campaign-grid">
        <% campaigns.forEach(function(c) { %>
        <article class="campaign-card reveal">
          <div class="campaign-header">
            <span class="campaign-platform"><%= c.platform || 'Multi-plateforme' %></span>
            <h3><%= c.client_name %></h3>
          </div>
          <p class="campaign-objective"><%= c.objective || '' %></p>
          <% if (c.results) { %>
          <div class="campaign-results"><%= c.results %></div>
          <% } %>
          <% if (c.statistics && Object.keys(c.statistics).length > 0) { %>
          <div class="campaign-stats">
            <% Object.entries(c.statistics).forEach(function([key, val]) { %>
            <div class="campaign-stat"><span class="campaign-stat-value"><%= val %></span><span class="campaign-stat-label"><%= key %></span></div>
            <% }); %>
          </div>
          <% } %>
        </article>
        <% }); %>
      </div>
      <div class="section-cta reveal">
        <a href="/campagnes" class="btn btn-outline">Toutes les campagnes</a>
      </div>
    </div>
  </section>
  <% } %>

  <!-- Blog -->
  <% if (posts.length > 0) { %>
  <section class="section section-blog bg-subtle">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-tag">Blog</span>
        <h2>Derniers articles</h2>
      </div>
      <div class="blog-grid">
        <% posts.forEach(function(post) { %>
        <article class="blog-card reveal">
          <% if (post.image) { %>
          <a href="/blog/<%= post.slug %>" class="blog-image"><img src="<%= post.image %>" alt="<%= post.title %>" loading="lazy"></a>
          <% } %>
          <div class="blog-body">
            <span class="blog-category"><%= post.category || 'Article' %></span>
            <h3><a href="/blog/<%= post.slug %>"><%= post.title %></a></h3>
            <time datetime="<%= post.created_at %>"><%= new Date(post.created_at).toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' }) %></time>
          </div>
        </article>
        <% }); %>
      </div>
      <div class="section-cta reveal">
        <a href="/blog" class="btn btn-outline">Tous les articles</a>
      </div>
    </div>
  </section>
  <% } %>

  <!-- Témoignages -->
  <% if (testimonials.length > 0) { %>
  <section class="section section-testimonials">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-tag">Témoignages</span>
        <h2>Ce que disent mes clients</h2>
      </div>
      <div class="testimonial-grid">
        <% testimonials.forEach(function(t) { %>
        <blockquote class="testimonial-card reveal">
          <p>&ldquo;<%= t.content %>&rdquo;</p>
          <footer>
            <strong><%= t.name %></strong>
            <% if (t.role || t.company) { %>
            <span><%= [t.role, t.company].filter(Boolean).join(' — ') %></span>
            <% } %>
          </footer>
        </blockquote>
        <% }); %>
      </div>
    </div>
  </section>
  <% } %>

  <!-- Contact CTA -->
  <section class="section section-cta-final">
    <div class="container reveal">
      <h2>Un projet en tête ?</h2>
      <p>Décrivez votre besoin — développement, application ou stratégie marketing — et recevez une réponse personnalisée.</p>
      <a href="/contact" class="btn btn-primary btn-lg">Demander un projet</a>
    </div>
  </section>

  <%- include('../partials/footer') %>
  <script src="/js/main.js" defer></script>
</body>
</html>
