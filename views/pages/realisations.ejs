<!DOCTYPE html>
<html lang="fr">
<head>
  <%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/header') %>

  <section class="page-hero">
    <div class="container">
      <span class="section-tag">Réalisations</span>
      <h1>Projets web</h1>
      <p class="page-hero-lead">Sites, applications et solutions digitales développées pour mes clients.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <% if (projects.length === 0) { %>
      <p class="empty-state reveal">Les réalisations seront bientôt disponibles.</p>
      <% } else { %>
      <div class="project-grid project-grid-full">
        <% projects.forEach(function(p) { %>
        <article class="project-card reveal">
          <% if (p.cover_image) { %>
          <div class="project-image"><img src="<%= p.cover_image %>" alt="<%= p.title %>" loading="lazy"></div>
          <% } else { %>
          <div class="project-image project-image-placeholder"></div>
          <% } %>
          <div class="project-body">
            <span class="project-category"><%= p.category || 'Web' %></span>
            <h3><%= p.title %></h3>
            <p><%= p.description || '' %></p>
            <% if (p.technologies && p.technologies.length) { %>
            <div class="tech-tags">
              <% p.technologies.forEach(function(t) { %><span class="tech-tag"><%= t %></span><% }); %>
            </div>
            <% } %>
            <% if (p.project_url) { %>
            <a href="<%= p.project_url %>" target="_blank" rel="noopener" class="link-arrow">Voir le projet</a>
            <% } %>
          </div>
        </article>
        <% }); %>
      </div>
      <% } %>
    </div>
  </section>

  <%- include('../partials/footer') %>
  <script src="/js/main.js" defer></script>
</body>
</html>
