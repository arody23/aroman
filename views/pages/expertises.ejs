<!DOCTYPE html>
<html lang="fr">
<head>
  <%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/header') %>

  <section class="page-hero">
    <div class="container">
      <span class="section-tag">Expertises</span>
      <h1>Développement & Media Buying</h1>
      <p class="page-hero-lead">Deux domaines d'excellence, une vision unifiée de la performance digitale.</p>
    </div>
  </section>

  <section class="section" id="developpement">
    <div class="container">
      <div class="expertise-detail reveal">
        <div class="expertise-detail-header">
          <span class="section-tag">Développement</span>
          <h2>Solutions logicielles sur mesure</h2>
          <p>Je conçois et développe des produits digitaux adaptés aux enjeux de votre entreprise — de la première ligne de code à la mise en production.</p>
        </div>
        <div class="service-list">
          <div class="service-item reveal">
            <h3>Sites web professionnels</h3>
            <p>Sites vitrines et institutionnels, optimisés SEO, rapides et responsive. Une vitrine digitale à la hauteur de votre image.</p>
          </div>
          <div class="service-item reveal">
            <h3>Applications web & SaaS</h3>
            <p>Plateformes web complètes, abonnements, tableaux de bord et fonctionnalités avancées pour vos utilisateurs.</p>
          </div>
          <div class="service-item reveal">
            <h3>Logiciels d'entreprise</h3>
            <p>Logiciels comptables, de gestion, ERP légers et outils métier pour automatiser vos processus.</p>
          </div>
          <div class="service-item reveal">
            <h3>Applications métier & PWA</h3>
            <p>Applications progressives accessibles sur tous les appareils, même hors connexion.</p>
          </div>
          <div class="service-item reveal">
            <h3>Solutions IA</h3>
            <p>Intégration d'intelligence artificielle lorsque cela apporte une réelle valeur à votre produit.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-subtle" id="media-buying">
    <div class="container">
      <div class="expertise-detail reveal">
        <div class="expertise-detail-header">
          <span class="section-tag">Media Buying</span>
          <h2>Acquisition & performance publicitaire</h2>
          <p>J'achète et optimise les emplacements publicitaires là où se trouve votre audience, avec une approche data-driven et orientée résultats.</p>
        </div>
        <div class="service-list">
          <div class="service-item reveal">
            <h3>Facebook & Instagram Ads</h3>
            <p>Campagnes ciblées, créations publicitaires, tests A/B et optimisation continue du ROAS.</p>
          </div>
          <div class="service-item reveal">
            <h3>Google Ads</h3>
            <p>Search, Display, YouTube — visibilité sur le premier moteur de recherche mondial.</p>
          </div>
          <div class="service-item reveal">
            <h3>Stratégies marketing</h3>
            <p>Plans d'acquisition, allocation budgétaire et feuilles de route pour scaler durablement.</p>
          </div>
          <div class="service-item reveal">
            <h3>Optimisation de campagnes</h3>
            <p>Audits, restructuration et amélioration continue des performances publicitaires.</p>
          </div>
          <div class="service-item reveal">
            <h3>Consulting marketing</h3>
            <p>Conseil stratégique pour structurer votre présence digitale et vos investissements publicitaires.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-cta-final">
    <div class="container reveal">
      <h2>Quelle expertise vous intéresse ?</h2>
      <a href="/contact" class="btn btn-primary btn-lg">Demander un projet</a>
    </div>
  </section>

  <%- include('../partials/footer') %>
  <script src="/js/main.js" defer></script>
</body>
</html>
