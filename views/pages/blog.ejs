<!DOCTYPE html>
<html lang="fr">
<head>
  <%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/header') %>

  <section class="page-hero">
    <div class="container">
      <span class="section-tag">Blog</span>
      <h1>Articles & insights</h1>
      <p class="page-hero-lead">Développement, logiciels et marketing digital — retours d'expérience et conseils.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <% if (posts.length === 0) { %>
      <p class="empty-state reveal">Les articles seront bientôt disponibles.</p>
      <% } else { %>
      <div class="blog-grid blog-grid-full">
        <% posts.forEach(function(post) { %>
        <article class="blog-card reveal">
          <% if (post.image) { %>
          <a href="/blog/<%= post.slug %>" class="blog-image"><img src="<%= post.image %>" alt="<%= post.title %>" loading="lazy"></a>
          <% } %>
          <div class="blog-body">
            <span class="blog-category"><%= post.category || 'Article' %></span>
            <h3><a href="/blog/<%= post.slug %>"><%= post.title %></a></h3>
            <time datetime="<%= post.created_at %>"><%= new Date(post.created_at).toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' }) %></time>
          </div>
        </article>
        <% }); %>
      </div>
      <% } %>
    </div>
  </section>

  <%- include('../partials/footer') %>
  <script src="/js/main.js" defer></script>
</body>
</html>
