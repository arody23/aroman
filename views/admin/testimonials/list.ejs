<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
  <%- include('../partials/sidebar', { activePage: 'testimonials' }) %>
  <div class="admin-main">
    <header class="admin-topbar"><button class="admin-menu-toggle" id="admin-menu-toggle">☰</button><h1><%= title %></h1><a href="/<%= adminPath %>/testimonials/new" class="btn btn-primary btn-sm">+ Nouveau</a></header>
    <div class="admin-content">
      <table class="admin-table admin-table-full">
        <thead><tr><th>Nom</th><th>Entreprise</th><th>Contenu</th><th>Actions</th></tr></thead>
        <tbody>
          <% items.forEach(function(item) { %>
          <tr>
            <td><strong><%= item.name %></strong><br><small><%= item.role %></small></td>
            <td><%= item.company || '—' %></td>
            <td><%= item.content.substring(0,60) %>…</td>
            <td class="actions"><a href="/<%= adminPath %>/testimonials/<%= item.id %>/edit">Modifier</a>
              <form method="POST" action="/<%= adminPath %>/testimonials/<%= item.id %>/delete" onsubmit="return confirm('Supprimer ?')"><button type="submit" class="btn-danger">Suppr.</button></form></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
  <script>document.getElementById('admin-menu-toggle')?.addEventListener('click',()=>document.getElementById('admin-sidebar').classList.toggle('open'));</script>
</body>
</html>
