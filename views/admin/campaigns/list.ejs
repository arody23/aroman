<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
  <%- include('../partials/sidebar', { activePage: 'campaigns' }) %>
  <div class="admin-main">
    <header class="admin-topbar"><button class="admin-menu-toggle" id="admin-menu-toggle">☰</button><h1><%= title %></h1><a href="/<%= adminPath %>/campaigns/new" class="btn btn-primary btn-sm">+ Nouvelle</a></header>
    <div class="admin-content">
      <table class="admin-table admin-table-full">
        <thead><tr><th>Client</th><th>Plateforme</th><th>Résultats</th><th>Statut</th><th>Actions</th></tr></thead>
        <tbody>
          <% items.forEach(function(item) { %>
          <tr>
            <td><strong><%= item.client_name %></strong></td>
            <td><%= item.platform || '—' %></td>
            <td><%= item.results ? item.results.substring(0,50) : '—' %></td>
            <td><span class="badge <%= item.published ? 'badge-published' : 'badge-draft' %>"><%= item.published ? 'Publié' : 'Brouillon' %></span></td>
            <td class="actions"><a href="/<%= adminPath %>/campaigns/<%= item.id %>/edit">Modifier</a>
              <form method="POST" action="/<%= adminPath %>/campaigns/<%= item.id %>/delete" onsubmit="return confirm('Supprimer ?')"><button type="submit" class="btn-danger">Suppr.</button></form></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
  <script>document.getElementById('admin-menu-toggle')?.addEventListener('click',()=>document.getElementById('admin-sidebar').classList.toggle('open'));</script>
</body>
</html>
