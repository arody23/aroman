<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
  <%- include('../partials/sidebar', { activePage: 'campaigns' }) %>
  <div class="admin-main">
    <header class="admin-topbar"><button class="admin-menu-toggle" id="admin-menu-toggle">☰</button><h1><%= title %></h1></header>
    <div class="admin-content">
      <form class="admin-form" method="POST" action="<%= item ? '/' + adminPath + '/campaigns/' + item.id : '/' + adminPath + '/campaigns' %>" enctype="multipart/form-data">
        <div class="form-group"><label>Nom du client *</label><input type="text" name="client_name" value="<%= item ? item.client_name : '' %>" required></div>
        <div class="form-row">
          <div class="form-group"><label>Plateforme</label><input type="text" name="platform" value="<%= item ? item.platform : '' %>" placeholder="Facebook Ads, Google Ads…"></div>
          <div class="form-group"><label>Objectif</label><input type="text" name="objective" value="<%= item ? item.objective : '' %>"></div>
        </div>
        <div class="form-group"><label>Résultats obtenus</label><input type="text" name="results" value="<%= item ? item.results : '' %>" placeholder="+85% ventes, ROAS 4.8x…"></div>
        <div class="form-group"><label>Stratégie</label><textarea name="strategy" rows="3"><%= item ? item.strategy : '' %></textarea></div>
        <div class="form-group"><label>Description détaillée</label><textarea name="description" rows="4"><%= item ? item.description : '' %></textarea></div>
        <div class="form-group"><label>Statistiques (JSON)</label><input type="text" name="statistics" value="<%= item ? item.statistics : '{}' %>" placeholder='{"ROAS":"4.8x","Leads":"187"}'></div>
        <div class="form-group"><label>Commentaires</label><textarea name="comments" rows="2"><%= item ? item.comments : '' %></textarea></div>
        <div class="form-group"><label>Captures d'écran</label><input type="file" name="screenshots" accept="image/*" multiple>
          <% if (item && item.screenshots) { let ss=[]; try{ss=JSON.parse(item.screenshots)}catch(e){} %>
          <input type="hidden" name="existing_screenshots" value="<%= item.screenshots %>">
          <div class="preview-grid"><% ss.forEach(function(s){ %><img src="<%= s %>" class="preview-img"><% }); %></div><% } %>
        </div>
        <div class="form-row">
          <div class="form-group"><label>Ordre</label><input type="number" name="sort_order" value="<%= item ? item.sort_order : 0 %>"></div>
          <div class="form-group"><label class="checkbox-label"><input type="checkbox" name="published" value="1" <%= !item || item.published ? 'checked' : '' %>> Publié</label></div>
        </div>
        <button type="submit" class="btn btn-primary">Enregistrer</button>
        <a href="/<%= adminPath %>/campaigns" class="btn btn-outline">Annuler</a>
      </form>
    </div>
  </div>
  <script>document.getElementById('admin-menu-toggle')?.addEventListener('click',()=>document.getElementById('admin-sidebar').classList.toggle('open'));</script>
</body>
</html>
