<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
  <%- include('partials/sidebar', { activePage: 'analytics' }) %>
  <div class="admin-main">
    <header class="admin-topbar">
      <button class="admin-menu-toggle" id="admin-menu-toggle" aria-label="Menu">☰</button>
      <h1><%= title %></h1>
      <div class="admin-user">
        <div class="admin-user-avatar"><%= adminUsername.charAt(0).toUpperCase() %></div>
        <span><%= adminUsername %></span>
      </div>
    </header>
    <div class="admin-content">
      <div class="dashboard-hero">
        <div>
          <h2>Statistiques</h2>
          <p>Analyse détaillée du trafic et du comportement des visiteurs</p>
        </div>
      </div>

      <div class="stats-grid">
        <div class="stat-card stat-dark">
          <div class="stat-card-inner">
            <div>
              <span class="stat-num"><%= visitors %></span>
              <span class="stat-label">Visiteurs uniques</span>
            </div>
            <div class="stat-icon stat-icon-dark">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
            </div>
          </div>
        </div>
        <div class="stat-card stat-blue">
          <div class="stat-card-inner">
            <div>
              <span class="stat-num"><%= pageViews %></span>
              <span class="stat-label">Pages vues</span>
            </div>
            <div class="stat-icon stat-icon-blue">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </div>
          </div>
        </div>
      </div>

      <div class="chart-panel" style="margin-bottom:20px">
        <div class="chart-panel-header">
          <h2>Évolution du trafic — 7 derniers jours</h2>
          <span class="chart-panel-badge">Live</span>
        </div>
        <div class="chart-canvas-wrap">
          <canvas id="chart-traffic"></canvas>
        </div>
      </div>

      <div class="charts-row charts-row-equal">
        <div class="chart-panel">
          <div class="chart-panel-header"><h2>Sources de trafic</h2></div>
          <div class="chart-canvas-wrap chart-sm">
            <canvas id="chart-sources"></canvas>
          </div>
        </div>
        <div class="chart-panel">
          <div class="chart-panel-header"><h2>Par appareil</h2></div>
          <div class="chart-canvas-wrap chart-sm">
            <canvas id="chart-devices"></canvas>
          </div>
        </div>
      </div>

      <div class="charts-row charts-row-equal" style="margin-top:20px">
        <div class="chart-panel">
          <div class="chart-panel-header"><h2>Navigateurs</h2></div>
          <div class="chart-canvas-wrap chart-sm">
            <canvas id="chart-browsers"></canvas>
          </div>
        </div>
        <div class="chart-panel">
          <div class="chart-panel-header"><h2>Pages populaires</h2></div>
          <div class="chart-canvas-wrap chart-sm">
            <canvas id="chart-pages"></canvas>
          </div>
        </div>
      </div>

      <div class="admin-panel" style="margin-top:24px">
        <div class="admin-panel-header"><h2>Visiteurs récents</h2></div>
        <table class="admin-table admin-table-full">
          <thead>
            <tr><th>IP</th><th>Pays</th><th>Ville</th><th>Appareil</th><th>Navigateur</th><th>OS</th><th>Source</th><th>Dernière visite</th></tr>
          </thead>
          <tbody>
            <% if (recentVisitors.length === 0) { %>
            <tr><td colspan="8" class="empty">Aucun visiteur enregistré.</td></tr>
            <% } %>
            <% recentVisitors.forEach(function(v) { %>
            <tr>
              <td><%= v.ip_address || '—' %></td>
              <td><%= v.country || '—' %></td>
              <td><%= v.city || '—' %></td>
              <td><%= v.device %></td>
              <td><%= v.browser %></td>
              <td><%= v.os %></td>
              <td><%= v.source %></td>
              <td><%= v.last_visit %></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <script>window.__ADMIN_CHARTS__ = <%- JSON.stringify(chartData) %>;</script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
  <script src="/js/admin-charts.js"></script>
  <script>document.getElementById('admin-menu-toggle')?.addEventListener('click',()=>document.getElementById('admin-sidebar').classList.toggle('open'));</script>
</body>
</html>
