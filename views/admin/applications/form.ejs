<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
  <%- include('../partials/sidebar', { activePage: 'applications' }) %>
  <div class="admin-main">
    <header class="admin-topbar"><button class="admin-menu-toggle" id="admin-menu-toggle">☰</button><h1><%= title %></h1></header>
    <div class="admin-content">
      <form class="admin-form" method="POST" action="<%= item ? '/' + adminPath + '/applications/' + item.id : '/' + adminPath + '/applications' %>" enctype="multipart/form-data">
        <div class="form-group"><label>Titre *</label><input type="text" name="title" value="<%= item ? item.title : '' %>" required></div>
        <div class="form-group"><label>Description</label><textarea name="description" rows="4"><%= item ? item.description : '' %></textarea></div>
        <div class="form-row">
          <div class="form-group"><label>Plateforme</label><input type="text" name="platform" value="<%= item ? item.platform : '' %>" placeholder="Web, iOS, Android, PWA…"></div>
          <div class="form-group"><label>Technologies (JSON)</label><input type="text" name="technologies" value="<%= item ? item.technologies : '[]' %>"></div>
        </div>
        <div class="form-group"><label>Lien</label><input type="url" name="app_url" value="<%= item ? item.app_url : '' %>"></div>
        <div class="form-group"><label>Image</label><input type="file" name="image" accept="image/*"><% if (item && item.image) { %><input type="hidden" name="existing_image" value="<%= item.image %>"><img src="<%= item.image %>" class="preview-img"><% } %></div>
        <div class="form-row">
          <div class="form-group"><label>Ordre</label><input type="number" name="sort_order" value="<%= item ? item.sort_order : 0 %>"></div>
          <div class="form-group"><label class="checkbox-label"><input type="checkbox" name="published" value="1" <%= !item || item.published ? 'checked' : '' %>> Publié</label></div>
        </div>
        <button type="submit" class="btn btn-primary">Enregistrer</button>
        <a href="/<%= adminPath %>/applications" class="btn btn-outline">Annuler</a>
      </form>
    </div>
  </div>
  <script>document.getElementById('admin-menu-toggle')?.addEventListener('click',()=>document.getElementById('admin-sidebar').classList.toggle('open'));</script>
</body>
</html>
