<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
  <%- include('partials/sidebar', { activePage: 'dashboard' }) %>
  <div class="admin-main">
    <header class="admin-topbar">
      <button class="admin-menu-toggle" id="admin-menu-toggle" aria-label="Menu">☰</button>
      <h1><%= title %></h1>
      <div class="admin-user">
        <div class="admin-user-avatar"><%= adminUsername.charAt(0).toUpperCase() %></div>
        <span><%= adminUsername %></span>
      </div>
    </header>
    <div class="admin-content">
      <div class="dashboard-hero">
        <div>
          <h2>Tableau de bord</h2>
          <p>Vue d'ensemble de votre portfolio et de l'activité du site</p>
        </div>
        <a href="/" target="_blank" class="btn btn-outline btn-sm">Voir le site →</a>
      </div>

      <div class="stats-grid">
        <div class="stat-card stat-blue">
          <div class="stat-card-inner">
            <div>
              <span class="stat-num"><%= stats.projects %></span>
              <span class="stat-label">Projets</span>
            </div>
            <div class="stat-icon stat-icon-blue">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
            </div>
          </div>
        </div>
        <div class="stat-card stat-blue">
          <div class="stat-card-inner">
            <div>
              <span class="stat-num"><%= stats.applications %></span>
              <span class="stat-label">Applications</span>
            </div>
            <div class="stat-icon stat-icon-blue">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2"/></svg>
            </div>
          </div>
        </div>
        <div class="stat-card stat-yellow">
          <div class="stat-card-inner">
            <div>
              <span class="stat-num"><%= stats.campaigns %></span>
              <span class="stat-label">Campagnes</span>
            </div>
            <div class="stat-icon stat-icon-yellow">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            </div>
          </div>
        </div>
        <div class="stat-card stat-yellow">
          <div class="stat-card-inner">
            <div>
              <span class="stat-num"><%= stats.posts %></span>
              <span class="stat-label">Articles</span>
            </div>
            <div class="stat-icon stat-icon-yellow">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg>
            </div>
          </div>
        </div>
        <div class="stat-card highlight">
          <div class="stat-card-inner">
            <div>
              <span class="stat-num"><%= stats.contacts %></span>
              <span class="stat-label">Nouvelles demandes</span>
            </div>
            <div class="stat-icon stat-icon-yellow">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/></svg>
            </div>
          </div>
        </div>
        <div class="stat-card stat-dark">
          <div class="stat-card-inner">
            <div>
              <span class="stat-num"><%= stats.visitors %></span>
              <span class="stat-label">Visiteurs</span>
            </div>
            <div class="stat-icon stat-icon-dark">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
            </div>
          </div>
        </div>
        <div class="stat-card stat-dark">
          <div class="stat-card-inner">
            <div>
              <span class="stat-num"><%= stats.pageViews %></span>
              <span class="stat-label">Pages vues</span>
            </div>
            <div class="stat-icon stat-icon-dark">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </div>
          </div>
        </div>
      </div>

      <div class="charts-row">
        <div class="chart-panel">
          <div class="chart-panel-header">
            <h2>Trafic — 7 derniers jours</h2>
            <span class="chart-panel-badge">Live</span>
          </div>
          <div class="chart-canvas-wrap">
            <canvas id="chart-traffic"></canvas>
          </div>
        </div>
        <div class="chart-panel">
          <div class="chart-panel-header">
            <h2>Répartition du contenu</h2>
          </div>
          <div class="chart-canvas-wrap chart-sm">
            <canvas id="chart-content"></canvas>
          </div>
        </div>
      </div>

      <div class="admin-grid-2">
        <div class="admin-panel">
          <div class="admin-panel-header">
            <h2>Demandes récentes</h2>
          </div>
          <% if (recentContacts.length === 0) { %><p class="empty">Aucune demande.</p><% } else { %>
          <table class="admin-table">
            <% recentContacts.forEach(function(c) { %>
            <tr>
              <td><strong><%= c.name %></strong><br><small style="color:var(--gris-500)"><%= c.email %></small></td>
              <td><%= c.created_at %></td>
              <td><span class="badge badge-<%= c.status %>"><%= c.status %></span></td>
            </tr>
            <% }); %>
          </table>
          <% } %>
          <a href="/<%= adminPath %>/contacts" class="admin-link">Voir tout →</a>
        </div>
        <div class="admin-panel">
          <div class="admin-panel-header">
            <h2>Visiteurs récents</h2>
          </div>
          <% if (recentVisitors.length === 0) { %><p class="empty">Aucun visiteur.</p><% } else { %>
          <table class="admin-table">
            <% recentVisitors.forEach(function(v) { %>
            <tr>
              <td><%= v.device %></td>
              <td><%= v.browser %></td>
              <td><%= v.source %></td>
              <td><%= v.last_visit %></td>
            </tr>
            <% }); %>
          </table>
          <% } %>
          <a href="/<%= adminPath %>/analytics" class="admin-link">Statistiques →</a>
        </div>
      </div>
    </div>
  </div>
  <script>window.__ADMIN_CHARTS__ = <%- JSON.stringify(chartData) %>;</script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
  <script src="/js/admin-charts.js"></script>
  <script>document.getElementById('admin-menu-toggle')?.addEventListener('click',()=>document.getElementById('admin-sidebar').classList.toggle('open'));</script>
</body>
</html>
