<aside class="admin-sidebar" id="admin-sidebar">
  <div class="admin-brand">
    <a href="/<%= adminPath %>" class="admin-brand-link">
      <img src="/assets/img/logo.png" alt="Aroman EMETSHU">
      <div class="admin-brand-text">
        <strong>Aroman EMETSHU</strong>
        <small>Administration</small>
      </div>
    </a>
  </div>
  <nav>
    <a href="/<%= adminPath %>" class="<%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'active' : '' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
      Dashboard
    </a>
    <a href="/<%= adminPath %>/projects" class="<%= activePage === 'projects' ? 'active' : '' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
      Projets
    </a>
    <a href="/<%= adminPath %>/applications" class="<%= activePage === 'applications' ? 'active' : '' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12" y2="18"/></svg>
      Applications
    </a>
    <a href="/<%= adminPath %>/campaigns" class="<%= activePage === 'campaigns' ? 'active' : '' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
      Campagnes
    </a>
    <a href="/<%= adminPath %>/blog" class="<%= activePage === 'blog' ? 'active' : '' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
      Blog
    </a>
    <a href="/<%= adminPath %>/testimonials" class="<%= activePage === 'testimonials' ? 'active' : '' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      Témoignages
    </a>
    <a href="/<%= adminPath %>/contacts" class="<%= activePage === 'contacts' ? 'active' : '' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
      Demandes
    </a>
    <a href="/<%= adminPath %>/analytics" class="<%= activePage === 'analytics' ? 'active' : '' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
      Statistiques
    </a>
  </nav>
  <div class="admin-sidebar-footer">
    <a href="/" target="_blank" class="admin-site-link">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
      Voir le site
    </a>
    <form action="/<%= adminPath %>/logout" method="POST" class="admin-logout">
      <button type="submit">Déconnexion</button>
    </form>
  </div>
</aside>
