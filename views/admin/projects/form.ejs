<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
  <%- include('../partials/sidebar', { activePage: 'projects' }) %>
  <div class="admin-main">
    <header class="admin-topbar"><button class="admin-menu-toggle" id="admin-menu-toggle">☰</button><h1><%= title %></h1></header>
    <div class="admin-content">
      <form class="admin-form" method="POST" action="<%= item ? '/' + adminPath + '/projects/' + item.id : '/' + adminPath + '/projects' %>" enctype="multipart/form-data">
        <div class="form-group"><label for="title">Titre *</label><input type="text" id="title" name="title" value="<%= item ? item.title : '' %>" required></div>
        <div class="form-group"><label for="description">Description</label><textarea id="description" name="description" rows="4"><%= item ? item.description : '' %></textarea></div>
        <div class="form-row">
          <div class="form-group"><label for="category">Catégorie</label><input type="text" id="category" name="category" value="<%= item ? item.category : '' %>" placeholder="Site web, SaaS…"></div>
          <div class="form-group"><label for="project_date">Date</label><input type="text" id="project_date" name="project_date" value="<%= item ? item.project_date : '' %>" placeholder="2025"></div>
        </div>
        <div class="form-group"><label for="technologies">Technologies (JSON array)</label><input type="text" id="technologies" name="technologies" value="<%= item ? item.technologies : '[]' %>" placeholder='["React","Node.js"]'></div>
        <div class="form-group"><label for="project_url">Lien du projet</label><input type="url" id="project_url" name="project_url" value="<%= item ? item.project_url : '' %>"></div>
        <div class="form-group">
          <label for="cover_image">Image de couverture</label>
          <input type="file" id="cover_image" name="cover_image" accept="image/*">
          <% if (item && item.cover_image) { %><input type="hidden" name="existing_cover" value="<%= item.cover_image %>"><img src="<%= item.cover_image %>" class="preview-img" alt=""><% } %>
        </div>
        <div class="form-row">
          <div class="form-group"><label for="sort_order">Ordre</label><input type="number" id="sort_order" name="sort_order" value="<%= item ? item.sort_order : 0 %>"></div>
          <div class="form-group"><label class="checkbox-label"><input type="checkbox" name="published" value="1" <%= !item || item.published ? 'checked' : '' %>> Publié</label></div>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Enregistrer</button>
          <a href="/<%= adminPath %>/projects" class="btn btn-outline">Annuler</a>
        </div>
      </form>
    </div>
  </div>
  <script>document.getElementById('admin-menu-toggle')?.addEventListener('click',()=>document.getElementById('admin-sidebar').classList.toggle('open'));</script>
</body>
</html>
